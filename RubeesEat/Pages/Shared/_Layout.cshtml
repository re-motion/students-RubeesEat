@inject IWebHostEnvironment Environment
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Rubees Eat</title>
    <link href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/site.css"/>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    @RenderSection("Styles", required: false)

    <script type="text/javascript">const isTest = @(!Environment.IsProduction() ? "true" : "false");</script>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light" style ="background-color: #fbbf00">
    <a href="/./">
        <img src="/logo_dark.png" alt="Rubees Eat logo" class="logo" style="width: 40px; height: auto;"/>
    </a>
    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav mr-auto">
            <li class="nav-item active">
                <a class="nav-link" href="/./">Home <span class="sr-only">(current)</span></a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/SplitBill">Split a bill</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/ShowBills">Show bills</a>
            </li>
        </ul>
    </div>
</nav>

<div>
    <div class="container mt-3" style="max-width: 900px;">
    @RenderBody()
    </div>
</div>

<script src="/js/site.js"></script>
</body>
</html>