@page
@using System.Globalization
@inject IBillRepository billRepository
@inject IPersonRepository personRepository

<head>
    <link href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/site.css" />
</head>

<div class="container mt-3">
    <h1 class="text-center">Hello, @personRepository.GetCurrentUser().FirstName!</h1>

    @{
        var amount = billRepository.GetBalance(personRepository.GetCurrentUser());
        var isPositive = amount >= 0;
        var amountAsString = amount.ToString("C", CultureInfo.CreateSpecificCulture("de-DE"));
        var displayClass = isPositive ? "text-success" : "text-danger";
    }

    <div class="text-center mt-5">
        <span t-id="balance" class="p-3 border rounded @displayClass">@amountAsString</span>
    </div>

    <ul class="entryLines list-group mt-5 mx-auto" style="max-width: 900px;">
        @foreach (var item in billRepository.GetRecentBalanceChanges(personRepository.GetCurrentUser(), 1, 5))
        {
        <li class="list-group-item justify-content-between">
                <a class="text-decoration-none text-dark w-100" t-action="showBillDetails" href="BillDetails/@item.BillId">
                    <div class="amount-description">
                        <div class="row">
                            <div class="col-3 @(item.Amount < 0 ? "text-danger" : "text-success")" t-id="amount">
                                @item.Amount.ToString("C", CultureInfo.CreateSpecificCulture("de-DE"))
                            </div>
                            <div class="col-5" t-id="description">
                                @item.Description
                            </div>
                            <div class="col-4 text-end fst-italic" t-id="date">
                                @item.Date.ToString("D", CultureInfo.CreateSpecificCulture("en-US"))
                            </div>
                        </div>
                    </div>
                </a>
            </li>
        }
    </ul>
</div>